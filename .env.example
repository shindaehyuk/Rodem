# Supabase 프로젝트 설정 (대시보드 → Project Settings → API Keys)
SUPABASE_URL=https://dwqyubygqwrrhnahmcfv.supabase.co
# 주의: sb_publishable_... (공개 키)가 아니라 sb_secret_... (secret 키)를 넣어야 합니다.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# 관리자 계정 (미설정 시 admin / rodem1234)
ADMIN_ID=admin
ADMIN_PASSWORD=rodem1234

# 세션 쿠키 서명 키 — 운영 시 반드시 무작위 값으로 설정 (openssl rand -hex 32)
AUTH_SECRET=
